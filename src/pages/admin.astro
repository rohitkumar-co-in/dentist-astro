---
import '../styles/global.css';
import { clinic } from '../lib/site';

const adminUsername = clinic.adminUsername;
const adminPassword = clinic.adminPassword;
const clinicName = clinic.name;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Owner Dashboard | {clinicName}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <meta name="theme-color" content="#00B4D8" />
  </head>
  <body class="min-h-screen bg-[var(--surface)] text-[var(--text)] font-sans antialiased pb-12">
    
    <!-- ──────── LOGIN MODAL ──────── -->
    <div id="login-container" class="min-h-screen flex items-center justify-center px-4">
      <div class="card-elevated max-w-md w-full p-6 sm:p-8 text-center space-y-6">
        <span class="flex h-16 w-16 items-center justify-center rounded-full bg-paleAqua text-darkAqua mx-auto ring-8 ring-paleAqua/50">
          <svg class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </span>
        <div>
          <h2 class="text-2xl font-extrabold tracking-tight text-darkAqua">Clinic Admin Login</h2>
          <p class="mt-2 text-sm text-[var(--muted)]">Enter the admin password to manage booking records.</p>
        </div>
        <form id="login-form" class="space-y-4">
          <div>
            <input class="input-field text-center" type="text" id="admin-user" placeholder="Username" required />
          </div>
          <div>
            <input class="input-field text-center" type="password" id="admin-pass" placeholder="Password" required />
          </div>
          <button type="submit" class="action-btn-primary w-full min-h-12 text-base justify-center">
            Access Dashboard
          </button>
          <p id="login-error" class="hidden text-xs text-red-500 mt-2 font-medium"></p>
        </form>
      </div>
    </div>

    <!-- ──────── DASHBOARD CONTAINER ──────── -->
    <div id="dashboard-container" class="hidden">
      <!-- Navbar -->
      <nav class="sticky top-0 z-40 border-b border-[var(--border)] bg-white/90 shadow-sm backdrop-blur">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="flex h-10 w-10 items-center justify-center rounded-[12px] bg-paleAqua text-darkAqua">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </span>
            <div>
              <span class="text-xs font-semibold text-darkAqua uppercase tracking-wider block leading-none">Management</span>
              <span class="text-base font-bold text-slate-800 leading-none">{clinicName}</span>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <button id="refresh-btn" class="action-btn-secondary min-h-10 px-3 hover:bg-slate-50 transition" title="Refresh Data">
              <svg class="h-4 w-4 text-slate-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
            </button>
            <button id="logout-btn" class="action-btn min-h-10 px-4 text-sm font-semibold border border-red-200 bg-red-50 text-red-600 hover:bg-red-100 transition rounded-[12px]">
              Logout
            </button>
          </div>
        </div>
      </nav>

      <!-- Main Layout -->
      <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-8 space-y-8">
        
        <!-- Welcome section -->
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-800 tracking-tight">Appointments Overview</h1>
            <p class="text-sm text-[var(--muted)]">Monitor, search, confirm, reschedule or cancel customer bookings.</p>
          </div>
          <div class="flex items-center gap-3">
            <button id="download-csv-btn" class="action-btn-secondary min-h-11 justify-center border-slate-200 hover:bg-slate-50 gap-1.5 font-semibold text-slate-700">
              <svg class="h-4 w-4 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              Export CSV
            </button>
            <button id="open-add-modal-btn" class="action-btn-primary min-h-11 justify-center shadow-soft">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              Add Appointment
            </button>
          </div>
        </div>

        <!-- Metrics cards -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
          <!-- Card Total -->
          <div class="card-elevated p-4 flex flex-col justify-between min-h-24 transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-slate-300">
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Total Bookings</span>
              <span class="text-slate-400">
                <svg class="h-5 w-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
              </span>
            </div>
            <span class="text-3xl font-black text-slate-800 mt-2" id="metric-total">0</span>
          </div>
          <!-- Card Pending -->
          <div class="card-elevated p-4 border-amber-200 bg-amber-50/20 flex flex-col justify-between min-h-24 transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:shadow-amber-100/50 hover:border-amber-300">
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold text-amber-600 uppercase tracking-wider">Pending</span>
              <span>
                <svg class="h-5 w-5 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </span>
            </div>
            <span class="text-3xl font-black text-amber-600 mt-2" id="metric-pending">0</span>
          </div>
          <!-- Card Confirmed -->
          <div class="card-elevated p-4 border-emerald-200 bg-emerald-50/20 flex flex-col justify-between min-h-24 transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:shadow-emerald-100/50 hover:border-emerald-300">
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold text-emerald-600 uppercase tracking-wider">Confirmed</span>
              <span>
                <svg class="h-5 w-5 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </span>
            </div>
            <span class="text-3xl font-black text-emerald-600 mt-2" id="metric-confirmed">0</span>
          </div>
          <!-- Card Rescheduled -->
          <div class="card-elevated p-4 border-indigo-200 bg-indigo-50/20 flex flex-col justify-between min-h-24 transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:shadow-indigo-100/50 hover:border-indigo-300">
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold text-indigo-600 uppercase tracking-wider">Rescheduled</span>
              <span>
                <svg class="h-5 w-5 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </span>
            </div>
            <span class="text-3xl font-black text-indigo-600 mt-2" id="metric-rescheduled">0</span>
          </div>
          <!-- Card Cancelled -->
          <div class="card-elevated p-4 border-rose-200 bg-rose-50/20 flex flex-col justify-between min-h-24 transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:shadow-rose-100/50 hover:border-rose-300">
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold text-rose-600 uppercase tracking-wider">Cancelled</span>
              <span>
                <svg class="h-5 w-5 text-rose-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </span>
            </div>
            <span class="text-3xl font-black text-rose-600 mt-2" id="metric-cancelled">0</span>
          </div>
        </div>

        <!-- Clinic Insights Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4" id="insights-container">
          <!-- Stats Card 1: Clinical Efficiency -->
          <div class="card-elevated p-4 flex flex-col justify-between space-y-3 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Clinical Efficiency</span>
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-emerald-50 text-emerald-600">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              </span>
            </div>
            <div>
              <span class="text-2xl font-black text-slate-800" id="stat-efficiency">0%</span>
              <p class="text-[10px] text-slate-400 mt-0.5">Ratio of Confirmed & Rescheduled slots</p>
            </div>
            <div class="w-full bg-slate-100 rounded-full h-1.5 overflow-hidden">
              <div id="stat-efficiency-bar" class="bg-emerald-500 h-1.5 rounded-full transition-all duration-500" style="width: 0%"></div>
            </div>
          </div>

          <!-- Stats Card 2: Peak Service Demand -->
          <div class="card-elevated p-4 flex flex-col justify-between space-y-3 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Top Treatment</span>
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-indigo-50 text-indigo-600">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              </span>
            </div>
            <div>
              <span class="text-base font-extrabold text-slate-800 truncate block" id="stat-top-service">Loading...</span>
              <p class="text-[10px] text-slate-400 mt-0.5" id="stat-top-service-sub">Most booked treatment</p>
            </div>
            <div class="text-xs font-medium text-slate-500 flex items-center justify-between border-t border-slate-50 pt-2">
              <span>Total Booked:</span>
              <span id="stat-top-service-count" class="font-bold text-darkAqua">0</span>
            </div>
          </div>

          <!-- Stats Card 3: Daily Slot Density -->
          <div class="card-elevated p-4 flex flex-col justify-between space-y-3 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Schedule Density</span>
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-sky-50 text-sky-600">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </span>
            </div>
            <div>
              <span class="text-2xl font-black text-slate-800" id="stat-today-density">0 Slots</span>
              <p class="text-[10px] text-slate-400 mt-0.5">Booked for today</p>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="flex h-2 w-2 rounded-full bg-slate-400 animate-pulse" id="stat-today-status-dot"></span>
              <span class="text-[10px] font-semibold text-slate-500" id="stat-today-status">Checking load...</span>
            </div>
          </div>
        </div>

        <!-- Grid layout for filters & blocked dates side-by-side -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Control Center Card (2/3 width) -->
          <div class="lg:col-span-2 card-elevated p-5 space-y-4">
            <!-- Top Row: Search & Dropdowns -->
            <div class="flex flex-col gap-4 md:flex-row md:items-center justify-between">
              <!-- Search box -->
              <div class="relative flex-1">
                <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </span>
                <input class="input-field pl-10 pr-10" type="text" id="search-input" placeholder="Search by name, phone, service, ID..." />
                <button id="search-clear-btn" class="hidden absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 transition" title="Clear Search">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
              </div>
              <!-- Dropdowns -->
              <div class="flex flex-wrap items-center gap-3">
                <div class="w-40">
                  <select class="input-field py-2" id="filter-status">
                    <option value="ALL">All Statuses</option>
                    <option value="Pending">Pending</option>
                    <option value="Confirmed">Confirmed</option>
                    <option value="Rescheduled">Rescheduled</option>
                    <option value="Cancelled">Cancelled</option>
                  </select>
                </div>
                <div class="w-44">
                  <select class="input-field py-2" id="filter-date">
                    <option value="ALL">All Dates</option>
                    <option value="TODAY">Today</option>
                    <option value="YESTERDAY">Yesterday</option>
                    <option value="TOMORROW">Tomorrow</option>
                    <option value="THIS_WEEK">This Week</option>
                    <option value="LAST_WEEK">Last Week</option>
                    <option value="THIS_MONTH">This Month</option>
                    <option value="LAST_MONTH">Last Month</option>
                    <option value="CUSTOM">Custom Range...</option>
                  </select>
                </div>
                <!-- Custom Date Range Picker Container (hidden by default) -->
                <div id="custom-date-container" class="hidden flex items-center gap-2">
                  <input type="date" id="custom-start-date" class="input-field py-2 text-xs w-32 animate-none" />
                  <span class="text-xs text-slate-400 font-medium">to</span>
                  <input type="date" id="custom-end-date" class="input-field py-2 text-xs w-32 animate-none" />
                </div>
              </div>
            </div>

            <!-- Divider -->
            <div class="w-full border-t border-[var(--border)] opacity-60"></div>

            <!-- Bottom Row: Quick Filter Chips -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 pt-1">
              <!-- Quick Date Filters -->
              <div class="space-y-2">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Quick Date Presets</span>
                <div id="quick-date-chips" class="flex flex-wrap gap-2 overflow-x-auto pb-1 scrollbar-thin">
                  <!-- Generated dynamically in script -->
                </div>
              </div>
              <!-- Quick Status Filters -->
              <div class="space-y-2">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Quick Status Presets</span>
                <div id="quick-status-chips" class="flex flex-wrap gap-2 overflow-x-auto pb-1 scrollbar-thin">
                  <!-- Generated dynamically in script -->
                </div>
              </div>
            </div>
          </div>

          <!-- Doctor Leave / Out-of-Office Card (1/3 width) -->
          <div class="card-elevated p-5 flex flex-col space-y-4 justify-between">
            <div class="flex items-center justify-between border-b border-[var(--border)] pb-2">
              <div class="flex items-center gap-2">
                <span class="flex h-7 w-7 items-center justify-center rounded-full bg-rose-50 text-rose-600">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </span>
                <h3 class="text-sm font-bold text-slate-800">Doctor Leave / Out of Office</h3>
              </div>
            </div>

            <!-- Block Dates Form -->
            <form id="block-dates-form" class="space-y-3">
              <div class="grid grid-cols-2 gap-3">
                <label class="block">
                  <span class="mb-1.5 block text-sm font-medium text-slate-700">Start Date</span>
                  <input class="input-field animate-none" type="date" id="block-start-date" required />
                </label>
                <label class="block">
                  <span class="mb-1.5 block text-sm font-medium text-slate-700">End Date</span>
                  <input class="input-field animate-none" type="date" id="block-end-date" required />
                </label>
              </div>
              <label class="block">
                <span class="mb-1.5 block text-sm font-medium text-slate-700">Reason / Note</span>
                <input type="text" id="block-reason" placeholder="e.g. Leave, Conference" class="input-field animate-none" required />
              </label>
              <button type="submit" class="action-btn-primary min-h-11 w-full justify-center text-sm font-semibold">
                Block Selected Dates
              </button>
            </form>

            <div class="w-full border-t border-[var(--border)] opacity-60"></div>

            <!-- Blocked Dates List -->
            <div class="space-y-2 flex-1 flex flex-col min-h-[140px]">
              <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Currently Blocked Dates</span>
              <div id="blocked-dates-list" class="flex flex-col gap-1.5 max-h-[160px] overflow-y-auto pr-1 flex-1 text-xs">
                <p class="text-slate-400 italic text-center py-4">No dates currently blocked.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Bookings listing area -->
        <div id="loading-state" class="flex flex-col items-center justify-center py-20 text-slate-500">
          <!-- Spin Loader SVG -->
          <svg class="animate-spin h-10 w-10 text-darkAqua mb-4" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="font-medium text-sm">Fetching appointments from Google Sheets...</span>
        </div>

        <div id="empty-state" class="hidden card-elevated p-12 text-center text-slate-500 space-y-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-400 mx-auto">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </span>
          <h3 class="text-lg font-bold text-slate-800">No appointments found</h3>
          <p class="text-sm text-[var(--muted)]">Try adjusting your search terms or filters.</p>
        </div>

        <div id="bookings-sections-container" class="space-y-12">
          <!-- Sections like Today, Tomorrow, Upcoming, Past will be loaded here dynamically -->
        </div>

      </main>
    </div>

    <!-- ──────── RESCHEDULE INLINE DIALOG (OVERLAY) ──────── -->
    <div id="reschedule-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur px-4">
      <div class="card-elevated max-w-md w-full p-6 space-y-6">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-bold text-slate-800">Reschedule Appointment</h3>
          <button id="close-modal-btn" class="text-slate-400 hover:text-slate-600">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <form id="reschedule-form" class="space-y-4">
          <input type="hidden" id="reschedule-id" />
          <label class="block">
            <span class="mb-1.5 block text-sm font-medium text-slate-700">New Date</span>
            <input class="input-field" type="date" id="reschedule-date" required />
          </label>
          <label class="block">
            <span class="mb-1.5 block text-sm font-medium text-slate-700">New Time Slot</span>
            <select class="input-field" id="reschedule-time" required>
              <option value="">Select a time slot…</option>
              <option value="09:30">09:30 AM</option>
