    <!-- ──────── SCRIPT BLOCK ──────── -->
    <script define:vars={{ supabaseUrl: clinic.supabaseUrl, supabaseAnonKey: clinic.supabaseAnonKey }}>
      let bookingsData = [];
      let filteredBookings = [];
      let blockedDatesData = [];

      const loginContainer = document.getElementById('login-container');
      const dashboardContainer = document.getElementById('dashboard-container');
      const loginForm = document.getElementById('login-form');
      const adminUserInput = document.getElementById('admin-user');
      const adminPassInput = document.getElementById('admin-pass');
      const loginError = document.getElementById('login-error');
      
      const refreshBtn = document.getElementById('refresh-btn');
      const logoutBtn = document.getElementById('logout-btn');
      const downloadCsvBtn = document.getElementById('download-csv-btn');
      
      const searchInput = document.getElementById('search-input');
      const searchClearBtn = document.getElementById('search-clear-btn');
      const filterStatus = document.getElementById('filter-status');
      const filterDate = document.getElementById('filter-date');
      const customDateContainer = document.getElementById('custom-date-container');
      const customStartDate = document.getElementById('custom-start-date');
      const customEndDate = document.getElementById('custom-end-date');
      
      const loadingState = document.getElementById('loading-state');
      const emptyState = document.getElementById('empty-state');
      const bookingsSectionsContainer = document.getElementById('bookings-sections-container');

      // Reschedule Modal elements
      const rescheduleModal = document.getElementById('reschedule-modal');
      const rescheduleForm = document.getElementById('reschedule-form');
      const rescheduleId = document.getElementById('reschedule-id');
      const rescheduleDate = document.getElementById('reschedule-date');
      const rescheduleTime = document.getElementById('reschedule-time');
      const closeModalBtn = document.getElementById('close-modal-btn');
      const cancelRescheduleBtn = document.getElementById('cancel-reschedule-btn');

      // Add Appointment Modal elements
      const addAppointmentModal = document.getElementById('add-appointment-modal');
      const addAppointmentForm = document.getElementById('add-appointment-form');
      const openAddModalBtn = document.getElementById('open-add-modal-btn');
      const closeAddModalBtn = document.getElementById('close-add-modal-btn');
      const cancelAddBtn = document.getElementById('cancel-add-btn');

      // Reminder Modal elements
      const reminderModal = document.getElementById('reminder-modal');
      const closeReminderModalBtn = document.getElementById('close-reminder-modal-btn');
      const cancelReminderBtn = document.getElementById('cancel-reminder-btn');
      const reminderPatientName = document.getElementById('reminder-patient-name');
      const reminderPatientPhone = document.getElementById('reminder-patient-phone');
      const reminderPatientEmail = document.getElementById('reminder-patient-email');
      const reminderMessageText = document.getElementById('reminder-message-text');
      const reminderCopyBtn = document.getElementById('reminder-copy-btn');
      const reminderSmsBtn = document.getElementById('reminder-sms-btn');
      const reminderEmailBtn = document.getElementById('reminder-email-btn');
      const reminderWaBtn = document.getElementById('reminder-wa-btn');

      // Add form fields
      const addFirstName = document.getElementById('add-first-name');
      const addLastName = document.getElementById('add-last-name');
      const addPhone = document.getElementById('add-phone');
      const addEmail = document.getElementById('add-email');
      const addService = document.getElementById('add-service');
      const addDate = document.getElementById('add-date');
      const addTime = document.getElementById('add-time');
      const addMessage = document.getElementById('add-message');

      // Block Dates Elements
      const blockDatesForm = document.getElementById('block-dates-form');
      const blockStartDate = document.getElementById('block-start-date');
      const blockEndDate = document.getElementById('block-end-date');
      const blockReason = document.getElementById('block-reason');
      const blockedDatesList = document.getElementById('blocked-dates-list');

      // Set default min date in Indian Standard Time (IST)
      const getIndianDateString = () => {
        const now = new Date();
        const utc = now.getTime() + (now.getTimezoneOffset() * 60000);
        const ist = new Date(utc + (3600000 * 5.5));
        const year = ist.getFullYear();
        const month = String(ist.getMonth() + 1).padStart(2, '0');
        const day = String(ist.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
      };

      if (addDate) {
        addDate.min = getIndianDateString();
        addDate.value = getIndianDateString();
      }

      // Input listeners for manual add names (alphabets only)
      if (addFirstName) {
        addFirstName.addEventListener('input', (e) => {
          e.target.value = e.target.value.replace(/[^A-Za-z]/g, '');
        });
      }
      if (addLastName) {
        addLastName.addEventListener('input', (e) => {
          e.target.value = e.target.value.replace(/[^A-Za-z]/g, '');
        });
      }

      // Input listener for manual phone formatting (10 digits, XXXXX XXXXX)
      if (addPhone) {
        addPhone.addEventListener('input', (e) => {
          let val = e.target.value.replace(/\D/g, '');
          if (val.length > 10 && (val.startsWith('91') || val.startsWith('0'))) {
            if (val.startsWith('91')) val = val.substring(2);
            else if (val.startsWith('0')) val = val.substring(1);
          }
          val = val.substring(0, 10);
          if (val.length > 5) {
            e.target.value = val.substring(0, 5) + ' ' + val.substring(5);
          } else {
            e.target.value = val;
          }
        });
      }

      // Open / Close modal
      if (openAddModalBtn) {
        openAddModalBtn.addEventListener('click', () => {
          addAppointmentForm.reset();
          if (addDate) addDate.value = getIndianDateString();
          addAppointmentModal.classList.remove('hidden');
        });
      }
      if (closeAddModalBtn) closeAddModalBtn.addEventListener('click', () => addAppointmentModal.classList.add('hidden'));
      if (cancelAddBtn) cancelAddBtn.addEventListener('click', () => addAppointmentModal.classList.add('hidden'));

      // Submit manual booking
      if (addAppointmentForm) {
        addAppointmentForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          const firstName = addFirstName.value.trim();
          const lastName = addLastName.value.trim();
          const phone = addPhone.value.replace(/\s/g, '');
          const email = addEmail.value.trim();
          const service = addService.value;
          const date = addDate.value;
          const time = addTime.value;
          const message = addMessage.value.trim();

          addAppointmentModal.classList.add('hidden');
          loadingState.classList.remove('hidden');
          bookingsSectionsContainer.classList.add('hidden');

          // Generate sequential-like unique ID client-side
          const formattedDate = date.replace(/-/g, "");
          const randomSuffix = Math.floor(1000 + Math.random() * 9000);
          const generatedId = `A-${formattedDate}-${randomSuffix}`;

          try {
            const response = await fetch(`${supabaseUrl}/rest/v1/bookings`, {
              method: 'POST',
              headers: {
                'apikey': supabaseAnonKey,
                'Authorization': `Bearer ${supabaseAnonKey}`,
                'Content-Type': 'application/json',
                'Prefer': 'return=representation'
              },
              body: JSON.stringify({
                appointment_id: generatedId,
                first_name: firstName,
                last_name: lastName,
                phone: phone,
                email: email || null,
                service: service,
                date: date,
                time: time,
                message: message || null,
                status: 'Confirmed'
              })
            });

            if (!response.ok) throw new Error('Network response not OK');
            fetchBookings();
          } catch (err) {
            console.error(err);
            alert(`Failed to add booking: ${err.message}`);
            loadingState.classList.add('hidden');
            bookingsSectionsContainer.classList.remove('hidden');
          }
        });
      }

      // Username & Password Access Control
      const checkAccess = () => {
        const isLoggedIn = localStorage.getItem('clinic_admin_logged_in') === 'true';
        if (isLoggedIn) {
          loginContainer.classList.add('hidden');
          dashboardContainer.classList.remove('hidden');

          // Prefill start and end date for block dates form in IST
          const todayIST = getIndianDateString();
          if (blockStartDate) {
            blockStartDate.min = todayIST;
            blockStartDate.value = todayIST;
          }
          if (blockEndDate) {
            blockEndDate.min = todayIST;
            blockEndDate.value = todayIST;
          }

          fetchBookings();
          fetchBlockedDates();
        } else {
          loginContainer.classList.remove('hidden');
          dashboardContainer.classList.add('hidden');
        }
      };

      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const userVal = adminUserInput.value.trim();
        const passVal = adminPassInput.value.trim();
        
        loginError.classList.add('hidden');
        const loginBtn = loginForm.querySelector('button[type="submit"]');
        const originalText = loginBtn.textContent;
        loginBtn.disabled = true;
        loginBtn.textContent = 'Verifying...';

        try {
          const response = await fetch(`${supabaseUrl}/rest/v1/admin_credentials?username=eq.${encodeURIComponent(userVal)}&password=eq.${encodeURIComponent(passVal)}&select=username`, {
            headers: {
              'apikey': supabaseAnonKey,
              'Authorization': `Bearer ${supabaseAnonKey}`
            }
          });
          if (!response.ok) throw new Error('Authentication failed');
          const data = await response.json();
          if (data && data.length > 0) {
            localStorage.setItem('clinic_admin_logged_in', 'true');
            checkAccess();
          } else {
            loginError.textContent = 'Incorrect username or password. Please try again.';
            loginError.classList.remove('hidden');
          }
        } catch (err) {
          console.error(err);
          loginError.textContent = 'Connection error. Could not verify credentials.';
          loginError.classList.remove('hidden');
        } finally {
          loginBtn.disabled = false;
          loginBtn.textContent = originalText;
        }
      });

      logoutBtn.addEventListener('click', () => {
        localStorage.removeItem('clinic_admin_logged_in');
        if (adminUserInput) adminUserInput.value = '';
        if (adminPassInput) adminPassInput.value = '';
        checkAccess();
      });

      refreshBtn.addEventListener('click', async () => {
        const svg = refreshBtn.querySelector('svg');
        if (svg) svg.classList.add('animate-spin');
        await fetchBookings();
        if (svg) svg.classList.remove('animate-spin');
      });

      // API Actions
      const fetchBookings = async () => {
        if (!supabaseUrl || !supabaseAnonKey) {
          showError("Supabase configuration is missing.");
          return;
        }

        loadingState.classList.remove('hidden');
        bookingsSectionsContainer.classList.add('hidden');
        emptyState.classList.add('hidden');

        try {
          const response = await fetch(`${supabaseUrl}/rest/v1/bookings?select=*`, {
            headers: {
              'apikey': supabaseAnonKey,
              'Authorization': `Bearer ${supabaseAnonKey}`
            }
          });
          if (!response.ok) throw new Error('API server returned error');
          const data = await response.json();

          // Map database rows back to frontend properties
          bookingsData = (data || []).map(row => ({
            appointmentId: row.appointment_id,
            firstName: row.first_name,
            lastName: row.last_name,
            phone: row.phone,
            email: row.email,
            service: row.service,
            date: row.date,
            time: row.time,
            message: row.message,
            status: row.status,
            timestamp: row.created_at
          }));

          renderDashboard();
        } catch (err) {
          console.error(err);
          showError("Could not retrieve bookings from Supabase database.");
        } finally {
          loadingState.classList.add('hidden');
        }
      };

      // Blocked Dates Actions
      const fetchBlockedDates = async () => {
        if (!supabaseUrl || !supabaseAnonKey) return;
        try {
          const response = await fetch(`${supabaseUrl}/rest/v1/blocked_dates?order=blocked_date.asc`, {
            headers: {
              'apikey': supabaseAnonKey,
              'Authorization': `Bearer ${supabaseAnonKey}`
            }
          });
          if (response.ok) {
            blockedDatesData = await response.json();
            renderBlockedDates();
          } else {
            console.warn('Failed to fetch blocked dates from database (table may not exist yet):', response.status);
            blockedDatesData = [];
            renderBlockedDates();
          }
        } catch (err) {
          console.warn('Could not retrieve blocked dates:', err);
          blockedDatesData = [];
          renderBlockedDates();
        }
      };

      const renderBlockedDates = () => {
        if (!blockedDatesList) return;
        if (blockedDatesData.length === 0) {
          blockedDatesList.innerHTML = `<p class="text-slate-400 italic text-center py-4">No dates currently blocked.</p>`;
          return;
        }

        blockedDatesList.innerHTML = blockedDatesData.map(item => {
          const parts = item.blocked_date.split('-');
          const displayDate = parts.length === 3 ? `${parts[2]}/${parts[1]}/${parts[0]}` : item.blocked_date;
          return `
            <div class="flex items-center justify-between bg-slate-50 border border-slate-100 rounded-lg p-2 transition hover:bg-slate-100 animate-none">
              <div class="space-y-0.5 min-w-0 flex-1 pr-2">
                <span class="font-bold text-slate-800">${displayDate}</span>
                <span class="text-slate-500 text-[10px] block font-medium truncate" title="${item.reason || ''}">${item.reason || 'Leave'}</span>
              </div>
              <button type="button" class="text-red-500 hover:text-red-700 transition btn-delete-blocked-date p-1 shrink-0" data-date="${item.blocked_date}" title="Remove Block">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          `;
        }).join('');

        // Bind delete click event
        blockedDatesList.querySelectorAll('.btn-delete-blocked-date').forEach(btn => {
          btn.addEventListener('click', async () => {
            const dateVal = btn.getAttribute('data-date');
            if (confirm(`Are you sure you want to unblock appointments for ${dateVal}?`)) {
              btn.disabled = true;
              const success = await deleteBlockedDateAPI(dateVal);
              if (success) {
                await fetchBlockedDates();
              } else {
                btn.disabled = false;
              }
            }
          });
        });
      };

      const deleteBlockedDateAPI = async (dateVal) => {
        if (!supabaseUrl || !supabaseAnonKey) return false;
        try {
          const response = await fetch(`${supabaseUrl}/rest/v1/blocked_dates?blocked_date=eq.${dateVal}`, {
            method: 'DELETE',
            headers: {
              'apikey': supabaseAnonKey,
              'Authorization': `Bearer ${supabaseAnonKey}`
            }
          });
          return response.ok;
        } catch (err) {
          console.error('Error deleting blocked date:', err);
          return false;
        }
      };

      if (blockDatesForm) {
        blockDatesForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const start = blockStartDate.value;
          const end = blockEndDate.value;
          const reason = blockReason.value.trim();

          if (!start || !end) return;
          if (start > end) {
            alert('Start Date must be before or equal to End Date.');
            return;
          }

          const submitBtn = blockDatesForm.querySelector('button[type="submit"]');
          const originalText = submitBtn.textContent;
          submitBtn.disabled = true;
          submitBtn.textContent = 'Blocking...';

          // Generate all dates in the range (inclusive)
          const dates = [];
          let current = new Date(start);
          const last = new Date(end);
          while (current <= last) {
            const y = current.getFullYear();
            const m = String(current.getMonth() + 1).padStart(2, '0');
            const d = String(current.getDate()).padStart(2, '0');
            dates.push(`${y}-${m}-${d}`);
            current.setDate(current.getDate() + 1);
          }

          const rows = dates.map(dateStr => ({
            blocked_date: dateStr,
            reason: reason || "Leave"
          }));

          try {
            if (supabaseUrl && supabaseAnonKey) {
              const response = await fetch(`${supabaseUrl}/rest/v1/blocked_dates`, {
                method: 'POST',
                headers: {
                  'apikey': supabaseAnonKey,
                  'Authorization': `Bearer ${supabaseAnonKey}`,
                  'Content-Type': 'application/json',
                  'Prefer': 'resolution=merge-duplicates'
                },
                body: JSON.stringify(rows)
              });
              if (response.ok) {
                blockReason.value = '';
                // reset values to today
                const todayIST = getIndianDateString();
                blockStartDate.value = todayIST;
                blockEndDate.value = todayIST;
                await fetchBlockedDates();
              } else {
                throw new Error('Supabase insertion failed');
              }
            }
          } catch (err) {
            console.error('Failed to block dates:', err);
            alert(`Failed to block dates: ${err.message}`);
          } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
          }
        });
      }

      const updateBookingAPI = async (appointmentId, updates) => {
        if (!supabaseUrl || !supabaseAnonKey) return false;
        
        try {
          const dbUpdates = {};
          if (updates.status !== undefined) dbUpdates.status = updates.status;
          if (updates.date !== undefined) dbUpdates.date = updates.date;
          if (updates.time !== undefined) dbUpdates.time = updates.time;

          const response = await fetch(`${supabaseUrl}/rest/v1/bookings?appointment_id=eq.${appointmentId}`, {
            method: 'PATCH',
            headers: {
              'apikey': supabaseAnonKey,
              'Authorization': `Bearer ${supabaseAnonKey}`,
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(dbUpdates)
          });

          if (!response.ok) throw new Error('Update failed');
          return true;
        } catch (err) {
          console.error(err);
          alert(`Failed to update booking: ${err.message}`);
          return false;
        }
      };

      const showError = (msg) => {
        bookingsSectionsContainer.innerHTML = `<div class="card-elevated p-6 text-center text-red-500 border-red-200 bg-red-50/50 col-span-full">
          <p class="font-bold">Error</p>
          <p class="text-sm mt-1">${msg}</p>
        </div>`;
        bookingsSectionsContainer.classList.remove('hidden');
      };

      // Metrics & Render Logic
      const renderDashboard = () => {
        let pending = 0, confirmed = 0, rescheduled = 0, cancelled = 0;
        bookingsData.forEach(b => {
          const status = String(b.status || 'Pending').toLowerCase();
          if (status === 'confirmed') confirmed++;
          else if (status === 'rescheduled') rescheduled++;
          else if (status === 'cancelled') cancelled++;
          else pending++;
        });

        document.getElementById('metric-total').textContent = bookingsData.length;
        document.getElementById('metric-pending').textContent = pending;
        document.getElementById('metric-confirmed').textContent = confirmed;
        document.getElementById('metric-rescheduled').textContent = rescheduled;
        document.getElementById('metric-cancelled').textContent = cancelled;

        // Recalculate and update the Insights Widget
        updateInsights(pending, confirmed, rescheduled, cancelled);

        // Recalculate filter option counts and quick filter chips
        updateFilterCounts(pending, confirmed, rescheduled, cancelled);

        applyFilters();
      };

      const updateInsights = (pending, confirmed, rescheduled, cancelled) => {
        // Clinical Efficiency
        const completedOrConfirmed = confirmed + rescheduled;
        const totalExcludingCancelled = bookingsData.length - cancelled;
        const efficiency = totalExcludingCancelled > 0 ? Math.round((completedOrConfirmed / totalExcludingCancelled) * 100) : 0;
        
        const statEfficiency = document.getElementById('stat-efficiency');
        const statEfficiencyBar = document.getElementById('stat-efficiency-bar');
        if (statEfficiency) statEfficiency.textContent = `${efficiency}%`;
        if (statEfficiencyBar) statEfficiencyBar.style.width = `${efficiency}%`;

        // Peak Service Demand
        const serviceCounts = {};
        bookingsData.forEach(b => {
          if (b.service) {
            serviceCounts[b.service] = (serviceCounts[b.service] || 0) + 1;
          }
        });
        let topService = 'None';
        let topCount = 0;
        Object.keys(serviceCounts).forEach(s => {
          if (serviceCounts[s] > topCount) {
            topService = s;
            topCount = serviceCounts[s];
          }
        });

        const statTopService = document.getElementById('stat-top-service');
        const statTopServiceCount = document.getElementById('stat-top-service-count');
        if (statTopService) {
          statTopService.textContent = topService;
          statTopService.title = topService;
        }
        if (statTopServiceCount) statTopServiceCount.textContent = topCount;

        // Daily Slot Density
        const getISTDate = (offsetDays = 0) => {
          const now = new Date();
          const utc = now.getTime() + (now.getTimezoneOffset() * 60000);
          const ist = new Date(utc + (3600000 * 5.5) + (offsetDays * 86400000));
          return ist;
        };

        const formatISTDateString = (dateObj) => {
          const year = dateObj.getFullYear();
          const month = String(dateObj.getMonth() + 1).padStart(2, '0');
          const day = String(dateObj.getDate()).padStart(2, '0');
          return `${year}-${month}-${day}`;
        };

        const todayIST = formatISTDateString(getISTDate(0));
        const todayBookings = bookingsData.filter(b => b.date === todayIST && b.status !== 'Cancelled').length;

        const statTodayDensity = document.getElementById('stat-today-density');
        const statTodayStatusDot = document.getElementById('stat-today-status-dot');
        const statTodayStatus = document.getElementById('stat-today-status');

        if (statTodayDensity) statTodayDensity.textContent = `${todayBookings} Slot${todayBookings !== 1 ? 's' : ''}`;

        if (statTodayStatusDot && statTodayStatus) {
          statTodayStatusDot.className = 'flex h-2 w-2 rounded-full animate-pulse';
          if (todayBookings === 0) {
            statTodayStatus.textContent = 'No slots booked';
            statTodayStatusDot.classList.add('bg-slate-400');
          } else if (todayBookings <= 3) {
            statTodayStatus.textContent = 'Light schedule load';
            statTodayStatusDot.classList.add('bg-emerald-500');
          } else if (todayBookings <= 6) {
            statTodayStatus.textContent = 'Optimal schedule load';
            statTodayStatusDot.classList.add('bg-amber-500');
          } else {
            statTodayStatus.textContent = 'High schedule load (Busy)';
            statTodayStatusDot.classList.add('bg-rose-500');
          }
        }
      };

      const updateFilterCounts = (pending, confirmed, rescheduled, cancelled) => {
        const getISTDate = (offsetDays = 0) => {
          const now = new Date();
          const utc = now.getTime() + (now.getTimezoneOffset() * 60000);
          const ist = new Date(utc + (3600000 * 5.5) + (offsetDays * 86400000));
          return ist;
        };

        const formatISTDateString = (dateObj) => {
          const year = dateObj.getFullYear();
          const month = String(dateObj.getMonth() + 1).padStart(2, '0');
          const day = String(dateObj.getDate()).padStart(2, '0');
          return `${year}-${month}-${day}`;
        };

        const getISTMonthBoundaries = (offsetMonths = 0) => {
          const todayIST = getISTDate();
          const year = todayIST.getFullYear();
          const month = todayIST.getMonth() + offsetMonths;
          const start = new Date(year, month, 1);
          const end = new Date(year, month + 1, 0);
          return {
            start: `${start.getFullYear()}-${String(start.getMonth() + 1).padStart(2, '0')}-01`,
            end: `${end.getFullYear()}-${String(end.getMonth() + 1).padStart(2, '0')}-${String(end.getDate()).padStart(2, '0')}`
          };
        };

        const todayIST = formatISTDateString(getISTDate(0));
        const yesterdayIST = formatISTDateString(getISTDate(-1));
        const tomorrowIST = formatISTDateString(getISTDate(1));

        const todayISTDateObj = getISTDate(0);
        const dayOfWeek = todayISTDateObj.getDay();
        const distanceToMonday = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;
        const thisWeekStart = formatISTDateString(getISTDate(distanceToMonday));
        const thisWeekEnd = formatISTDateString(getISTDate(distanceToMonday + 6));
        const lastWeekStart = formatISTDateString(getISTDate(distanceToMonday - 7));
        const lastWeekEnd = formatISTDateString(getISTDate(distanceToMonday - 1));

        const thisMonthBoundaries = getISTMonthBoundaries(0);
        const lastMonthBoundaries = getISTMonthBoundaries(-1);

        let statusCounts = { ALL: bookingsData.length, Pending: pending, Confirmed: confirmed, Rescheduled: rescheduled, Cancelled: cancelled };
        let dateCounts = {
          ALL: bookingsData.length,
          TODAY: 0,
          YESTERDAY: 0,
          TOMORROW: 0,
          THIS_WEEK: 0,
          LAST_WEEK: 0,
          THIS_MONTH: 0,
          LAST_MONTH: 0
        };

        bookingsData.forEach(b => {
          const bDate = b.date || '';
          if (bDate === todayIST) dateCounts.TODAY++;
          else if (bDate === yesterdayIST) dateCounts.YESTERDAY++;
          else if (bDate === tomorrowIST) dateCounts.TOMORROW++;

          if (bDate >= thisWeekStart && bDate <= thisWeekEnd) dateCounts.THIS_WEEK++;
          if (bDate >= lastWeekStart && bDate <= lastWeekEnd) dateCounts.LAST_WEEK++;
          if (bDate >= thisMonthBoundaries.start && bDate <= thisMonthBoundaries.end) dateCounts.THIS_MONTH++;
          if (bDate >= lastMonthBoundaries.start && bDate <= lastMonthBoundaries.end) dateCounts.LAST_MONTH++;
        });

        const statusMap = {
          'ALL': `All Statuses (${statusCounts.ALL})`,
          'Pending': `Pending (${statusCounts.Pending})`,
          'Confirmed': `Confirmed (${statusCounts.Confirmed})`,
          'Rescheduled': `Rescheduled (${statusCounts.Rescheduled})`,
          'Cancelled': `Cancelled (${statusCounts.Cancelled})`
        };

        const dateMap = {
          'ALL': `All Dates (${dateCounts.ALL})`,
          'TODAY': `Today (${dateCounts.TODAY})`,
          'YESTERDAY': `Yesterday (${dateCounts.YESTERDAY})`,
          'TOMORROW': `Tomorrow (${dateCounts.TOMORROW})`,
          'THIS_WEEK': `This Week (${dateCounts.THIS_WEEK})`,
          'LAST_WEEK': `Last Week (${dateCounts.LAST_WEEK})`,
          'THIS_MONTH': `This Month (${dateCounts.THIS_MONTH})`,
          'LAST_MONTH': `Last Month (${dateCounts.LAST_MONTH})`,
        };

        Object.keys(statusMap).forEach(val => {
          const opt = filterStatus.querySelector(`option[value="${val}"]`);
          if (opt) opt.textContent = statusMap[val];
        });

        Object.keys(dateMap).forEach(val => {
          const opt = filterDate.querySelector(`option[value="${val}"]`);
          if (opt) opt.textContent = dateMap[val];
        });

        renderQuickFilterChips(dateCounts, statusCounts);
      };

      const renderQuickFilterChips = (dateCounts, statusCounts) => {
        const quickDateChips = document.getElementById('quick-date-chips');
        const quickStatusChips = document.getElementById('quick-status-chips');
        if (!quickDateChips || !quickStatusChips) return;

        const activeDate = filterDate.value;
        const activeStatus = filterStatus.value;

        const dateChipsData = [
          { value: 'ALL', label: 'All Dates', count: dateCounts.ALL },
          { value: 'TODAY', label: 'Today', count: dateCounts.TODAY },
          { value: 'YESTERDAY', label: 'Yesterday', count: dateCounts.YESTERDAY },
          { value: 'TOMORROW', label: 'Tomorrow', count: dateCounts.TOMORROW },
          { value: 'THIS_WEEK', label: 'This Week', count: dateCounts.THIS_WEEK },
          { value: 'LAST_WEEK', label: 'Last Week', count: dateCounts.LAST_WEEK },
          { value: 'THIS_MONTH', label: 'This Month', count: dateCounts.THIS_MONTH },
          { value: 'LAST_MONTH', label: 'Last Month', count: dateCounts.LAST_MONTH },
        ];

        const statusChipsData = [
          { value: 'ALL', label: 'All Statuses', count: statusCounts.ALL },
          { value: 'Pending', label: 'Pending', count: statusCounts.Pending, dot: 'bg-amber-500' },
          { value: 'Confirmed', label: 'Confirmed', count: statusCounts.Confirmed, dot: 'bg-emerald-500' },
          { value: 'Rescheduled', label: 'Rescheduled', count: statusCounts.Rescheduled, dot: 'bg-indigo-500' },
          { value: 'Cancelled', label: 'Cancelled', count: statusCounts.Cancelled, dot: 'bg-rose-500' },
        ];

        quickDateChips.innerHTML = dateChipsData.map(chip => {
          const isActive = chip.value === activeDate;
          const activeClass = isActive
            ? 'bg-darkAqua text-white border-darkAqua shadow-sm shadow-darkAqua/10'
            : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50';
          return `
            <button type="button" class="btn-date-chip inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold border rounded-full transition-all duration-200 ${activeClass}" data-value="${chip.value}">
              <span>${chip.label}</span>
              <span class="opacity-70">(${chip.count})</span>
            </button>
          `;
        }).join('');

        quickStatusChips.innerHTML = statusChipsData.map(chip => {
          const isActive = chip.value === activeStatus;
          const activeClass = isActive
            ? 'bg-darkAqua text-white border-darkAqua shadow-sm shadow-darkAqua/10'
            : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50';
          const dotHtml = chip.dot ? `<span class="h-2 w-2 rounded-full ${chip.dot}"></span>` : '';
          return `
            <button type="button" class="btn-status-chip inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold border rounded-full transition-all duration-200 ${activeClass}" data-value="${chip.value}">
              ${dotHtml}
              <span>${chip.label}</span>
              <span class="opacity-70">(${chip.count})</span>
            </button>
          `;
        }).join('');

        quickDateChips.querySelectorAll('.btn-date-chip').forEach(btn => {
          btn.addEventListener('click', () => {
            const val = btn.dataset.value;
            filterDate.value = val;
            filterDate.dispatchEvent(new Event('change'));
          });
        });

        quickStatusChips.querySelectorAll('.btn-status-chip').forEach(btn => {
          btn.addEventListener('click', () => {
            const val = btn.dataset.value;
            filterStatus.value = val;
            filterStatus.dispatchEvent(new Event('change'));
          });
        });
      };

      const highlightText = (text) => {
        if (!text) return '';
        const query = searchInput.value.toLowerCase().trim();
        if (!query) return text;
        const escapedQuery = query.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&');
        const regex = new RegExp(`(${escapedQuery})`, 'gi');
        return String(text).replace(regex, '<mark class="bg-yellow-200 text-slate-900 px-0.5 rounded">$1</mark>');
      };

      const format12Hour = (timeStr) => {
        if (!timeStr) return '';
        const parts = timeStr.split(':');
        if (parts.length < 2) return timeStr;
        const hr = parseInt(parts[0], 10);
        const min = parts[1];
        const ampm = hr >= 12 ? 'PM' : 'AM';
        const displayHr = hr % 12 || 12;
        return `${String(displayHr).padStart(2, '0')}:${min} ${ampm}`;
      };

      const generateCardHtml = (b) => {
        let statusColorClass = 'border-amber-200 bg-amber-50 text-amber-700';
        let accentBorder = 'border-l-4 border-l-amber-400';
        const status = String(b.status || 'Pending').toLowerCase();
        
        if (status === 'confirmed') {
          statusColorClass = 'border-emerald-200 bg-emerald-50 text-emerald-700';
          accentBorder = 'border-l-4 border-l-emerald-500';
        } else if (status === 'rescheduled') {
          statusColorClass = 'border-indigo-200 bg-indigo-50 text-indigo-700';
          accentBorder = 'border-l-4 border-l-indigo-500';
        } else if (status === 'cancelled') {
          statusColorClass = 'border-rose-200 bg-rose-50 text-rose-700';
          accentBorder = 'border-l-4 border-l-rose-500';
        }

        const phoneStr = String(b.phone || '');
        const formattedDateParts = (b.date || '').split('-');
        const displayDate = formattedDateParts.length === 3 
          ? `${formattedDateParts[2]}/${formattedDateParts[1]}/${formattedDateParts[0]}`
          : b.date;

        const time12 = format12Hour(b.time);
        const isActionable = status !== 'cancelled';

        const patientName = `${b.firstName} ${b.lastName}`;
        const highlightedName = highlightText(patientName);
        const highlightedId = highlightText(b.appointmentId);
        const highlightedService = highlightText(b.service);
        const highlightedPhone = highlightText(`+91 ${phoneStr.substring(0,5)} ${phoneStr.substring(5)}`);
        const highlightedEmail = b.email ? highlightText(b.email) : '';

        // Initials Avatar
        const initials = ((b.firstName || '').substring(0,1) + (b.lastName || '').substring(0,1)).toUpperCase();
        const colors = [
          'bg-cyan-100 text-cyan-700',
          'bg-emerald-100 text-emerald-700',
          'bg-indigo-100 text-indigo-700',
          'bg-purple-100 text-purple-700',
          'bg-pink-100 text-pink-700',
          'bg-teal-100 text-teal-700',
          'bg-amber-100 text-amber-700'
        ];
        const nameSum = (b.firstName + b.lastName).split('').reduce((sum, c) => sum + c.charCodeAt(0), 0);
        const avatarColorClass = colors[nameSum % colors.length];

        return `
          <div class="card-elevated p-5 flex flex-col justify-between space-y-4 relative overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-md ${accentBorder}">
            <div class="space-y-3">
              <!-- ID & Status Badge -->
              <div class="flex items-center justify-between">
                <span class="text-xs font-bold text-slate-500 font-mono tracking-tight bg-slate-100 px-2.5 py-1 rounded-md">
                  ID: ${highlightedId}
                </span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold border ${statusColorClass}">
                  ${b.status || 'Pending'}
                </span>
              </div>

              <!-- Patient Basic Info -->
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-xs font-bold ${avatarColorClass}">
                  ${initials}
                </span>
                <div>
                  <h4 class="text-base font-bold text-slate-800 leading-tight">${highlightedName}</h4>
                  <p class="text-[10px] text-slate-400 mt-0.5">Created: ${new Date(b.timestamp).toLocaleString('en-IN')}</p>
                </div>
              </div>

              <!-- Clinical Details Grid -->
              <div class="grid grid-cols-1 gap-2 text-xs bg-slate-50/50 p-3 rounded-lg border border-slate-100/80">
                <!-- Preferred Slot -->
                <div class="flex items-start gap-2">
                  <span class="mt-0.5 text-slate-400">
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  </span>
                  <div>
                    <span class="text-slate-400 block text-[9px] uppercase tracking-wider font-semibold">Scheduled Slot</span>
                    <span class="font-semibold text-slate-800">${displayDate} · ${time12}</span>
                  </div>
                </div>
                <!-- Service -->
                <div class="flex items-start gap-2">
                  <span class="mt-0.5 text-slate-400">
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                  </span>
                  <div>
                    <span class="text-slate-400 block text-[9px] uppercase tracking-wider font-semibold">Treatment / Service</span>
                    <span class="font-medium text-slate-800">${highlightedService}</span>
                  </div>
                </div>
                <!-- Phone -->
                <div class="flex items-start gap-2">
                  <span class="mt-0.5 text-slate-400">
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  </span>
                  <div>
                    <span class="text-slate-400 block text-[9px] uppercase tracking-wider font-semibold">Phone</span>
                    <a href="tel:+91${phoneStr}" class="font-bold text-darkAqua hover:underline">${highlightedPhone}</a>
                  </div>
                </div>
                <!-- Email -->
                ${b.email ? `
                <div class="flex items-start gap-2">
                  <span class="mt-0.5 text-slate-400">
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </span>
                  <div>
                    <span class="text-slate-400 block text-[9px] uppercase tracking-wider font-semibold">Email</span>
                    <a href="mailto:${b.email}" class="text-darkAqua hover:underline truncate block max-w-[180px]" title="${b.email}">${highlightedEmail}</a>
                  </div>
                </div>` : ''}
              </div>

              ${b.message ? `
              <div class="bg-slate-50 rounded-lg p-2.5 text-xs text-slate-500 italic mt-2 border border-slate-100">
                "${b.message}"
              </div>` : ''}
            </div>

            <!-- Button actions -->
            <div class="pt-2 flex flex-col gap-2">
              <div class="flex items-center gap-2 font-medium">
                <button class="action-btn-secondary min-h-9 text-xs py-1.5 w-full justify-center gap-1.5 hover:bg-indigo-50 hover:border-indigo-200 hover:text-indigo-700 btn-trigger-reminder transition"
                  data-id="${b.appointmentId}"
                  data-firstname="${b.firstName}"
                  data-lastname="${b.lastName}"
                  data-phone="${phoneStr}"
                  data-email="${b.email || ''}"
                  data-date="${displayDate}"
                  data-time="${time12}"
                  data-service="${b.service}">
                  <svg class="h-3.5 w-3.5 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                  Remind Client
                </button>
                <a href="tel:+91${phoneStr}" class="action-btn-secondary min-h-9 text-xs py-1.5 px-3 justify-center gap-1.5 hover:bg-slate-50 transition" title="Call Client">
                  <svg class="h-3.5 w-3.5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  Call
                </a>
              </div>
              ${isActionable ? `
              <div class="flex items-center gap-2">
                ${status !== 'confirmed' ? `
                <button class="action-btn-primary min-h-9 text-xs py-1.5 w-full bg-emerald-600 hover:bg-emerald-700 justify-center btn-confirm" data-id="${b.appointmentId}">
                  Confirm
                </button>` : ''}
                <button class="action-btn-secondary min-h-9 text-xs py-1.5 w-full justify-center text-indigo-600 border-indigo-200 bg-indigo-50/20 hover:bg-indigo-50 btn-reschedule" data-id="${b.appointmentId}" data-date="${b.date}" data-time="${b.time}">
                  Reschedule
                </button>
                <button class="action-btn-secondary min-h-9 text-xs py-1.5 px-2.5 text-red-600 border-red-200 bg-red-50/20 hover:bg-red-50 btn-cancel" data-id="${b.appointmentId}">
                  Cancel
                </button>
              </div>` : ''}
            </div>
          </div>
        `;
      };

      const applyFilters = () => {
        const query = searchInput.value.toLowerCase().trim();
        const statusVal = filterStatus.value;
        const dateVal = filterDate.value;

        // Helpers for IST date boundaries
        const getISTDate = (offsetDays = 0) => {
          const now = new Date();
          const utc = now.getTime() + (now.getTimezoneOffset() * 60000);
          const ist = new Date(utc + (3600000 * 5.5) + (offsetDays * 86400000));
          return ist;
        };

        const formatISTDateString = (dateObj) => {
          const year = dateObj.getFullYear();
          const month = String(dateObj.getMonth() + 1).padStart(2, '0');
          const day = String(dateObj.getDate()).padStart(2, '0');
          return `${year}-${month}-${day}`;
        };

        const getISTMonthBoundaries = (offsetMonths = 0) => {
          const todayIST = getISTDate();
          const year = todayIST.getFullYear();
          const month = todayIST.getMonth() + offsetMonths;
          const start = new Date(year, month, 1);
          const end = new Date(year, month + 1, 0);
          return {
            start: `${start.getFullYear()}-${String(start.getMonth() + 1).padStart(2, '0')}-01`,
            end: `${end.getFullYear()}-${String(end.getMonth() + 1).padStart(2, '0')}-${String(end.getDate()).padStart(2, '0')}`
          };
        };

        let filterStartDate = null;
        let filterEndDate = null;

        const todayISTDateObj = getISTDate(0);
        const todayISTStr = formatISTDateString(todayISTDateObj);
        const todayIST = todayISTStr;
        const tomorrowIST = formatISTDateString(getISTDate(1));

        if (dateVal === 'TODAY') {
          filterStartDate = todayISTStr;
          filterEndDate = todayISTStr;
        } else if (dateVal === 'YESTERDAY') {
          const yesterdayStr = formatISTDateString(getISTDate(-1));
          filterStartDate = yesterdayStr;
          filterEndDate = yesterdayStr;
        } else if (dateVal === 'TOMORROW') {
          const tomorrowStr = formatISTDateString(getISTDate(1));
          filterStartDate = tomorrowStr;
          filterEndDate = tomorrowStr;
        } else if (dateVal === 'THIS_WEEK') {
          const dayOfWeek = todayISTDateObj.getDay(); // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
          const distanceToMonday = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;
          filterStartDate = formatISTDateString(getISTDate(distanceToMonday));
          filterEndDate = formatISTDateString(getISTDate(distanceToMonday + 6));
        } else if (dateVal === 'LAST_WEEK') {
          const dayOfWeek = todayISTDateObj.getDay();
          const distanceToMonday = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;
          filterStartDate = formatISTDateString(getISTDate(distanceToMonday - 7));
          filterEndDate = formatISTDateString(getISTDate(distanceToMonday - 1));
        } else if (dateVal === 'THIS_MONTH') {
          const boundaries = getISTMonthBoundaries(0);
          filterStartDate = boundaries.start;
          filterEndDate = boundaries.end;
        } else if (dateVal === 'LAST_MONTH') {
          const boundaries = getISTMonthBoundaries(-1);
          filterStartDate = boundaries.start;
          filterEndDate = boundaries.end;
        } else if (dateVal === 'CUSTOM') {
          filterStartDate = customStartDate.value || null;
          filterEndDate = customEndDate.value || null;
        }

        const filtered = bookingsData.filter(b => {
          // Status filter
          const status = b.status || 'Pending';
          if (statusVal !== 'ALL' && status.toLowerCase() !== statusVal.toLowerCase()) {
            return false;
          }

          // Date filter
          const bookingDate = b.date || '';
          if (dateVal !== 'ALL') {
            if (filterStartDate && bookingDate < filterStartDate) return false;
            if (filterEndDate && bookingDate > filterEndDate) return false;
          }

          // Search query matching
          if (query) {
            const matchesId = String(b.appointmentId || '').toLowerCase().includes(query);
            const matchesName = `${b.firstName} ${b.lastName}`.toLowerCase().includes(query);
            const matchesPhone = String(b.phone || '').includes(query);
            const matchesService = String(b.service || '').toLowerCase().includes(query);
            const matchesEmail = String(b.email || '').toLowerCase().includes(query);

            if (!matchesId && !matchesName && !matchesPhone && !matchesService && !matchesEmail) {
              return false;
            }
          }

          return true;
        });

        filteredBookings = filtered;

        if (filtered.length === 0) {
          emptyState.classList.remove('hidden');
          bookingsSectionsContainer.classList.add('hidden');
        } else {
          emptyState.classList.add('hidden');
          bookingsSectionsContainer.innerHTML = '';

          // Group Bookings
          const todayGroup = [];
          const tomorrowGroup = [];
          const upcomingGroup = [];
          const pastGroup = [];

          filtered.forEach(b => {
            const bDate = b.date || '';
            if (bDate === todayIST) todayGroup.push(b);
            else if (bDate === tomorrowIST) tomorrowGroup.push(b);
            else if (bDate > todayIST) upcomingGroup.push(b);
            else pastGroup.push(b);
          });

          // Sort arrays chronologically by time slot
          const sortByTime = (arr) => {
            arr.sort((a, b) => (a.time || '00:00').localeCompare(b.time || '00:00'));
          };

          sortByTime(todayGroup);
          sortByTime(tomorrowGroup);
          sortByTime(upcomingGroup);

          // Past bookings sort by date DESC, then time DESC
          pastGroup.sort((a, b) => {
            const dateCompare = (b.date || '').localeCompare(a.date || '');
            if (dateCompare !== 0) return dateCompare;
            return (b.time || '').localeCompare(a.time || '');
          });

          // Renders Helper
          const renderSection = (title, group, themeColor, collapsible = false, collapsedDefault = false) => {
            if (group.length === 0) return '';
            const sectionId = `sec-${title.toLowerCase().replace(/\s/g, '-')}`;
            let cardsHtml = '';
            group.forEach(b => {
              cardsHtml += generateCardHtml(b);
            });
            
            return `
              <div class="space-y-4" id="${sectionId}-parent">
                <div class="flex items-center justify-between border-b border-[var(--border)] pb-2 cursor-pointer select-none" id="toggle-${sectionId}">
                  <div class="flex items-center gap-2">
                    <span class="h-3.5 w-3.5 rounded-full ${themeColor}"></span>
                    <h2 class="text-lg font-bold text-slate-800">${title} (${group.length})</h2>
                  </div>
                  ${collapsible ? `
                  <span class="text-xs font-semibold text-slate-400 hover:text-slate-600 block">
                    Show / Hide
                  </span>` : ''}
                </div>
                <div id="${sectionId}-grid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 ${collapsedDefault ? 'hidden' : ''}">
                  ${cardsHtml}
                </div>
              </div>
            `;
          };

          // Append Sections
          bookingsSectionsContainer.innerHTML += renderSection("Today's Schedule", todayGroup, "bg-emerald-500");
          bookingsSectionsContainer.innerHTML += renderSection("Tomorrow's Schedule", tomorrowGroup, "bg-indigo-500");
          bookingsSectionsContainer.innerHTML += renderSection("Upcoming Bookings", upcomingGroup, "bg-sky-500");
          bookingsSectionsContainer.innerHTML += renderSection("Past Appointments", pastGroup, "bg-slate-400", true, true);

          bookingsSectionsContainer.classList.remove('hidden');

          // Hook Collapsible listeners
          ["Today's Schedule", "Tomorrow's Schedule", "Upcoming Bookings", "Past Appointments"].forEach(title => {
            const sectionId = `sec-${title.toLowerCase().replace(/\s/g, '-')}`;
            const header = document.getElementById(`toggle-${sectionId}`);
            const grid = document.getElementById(`${sectionId}-grid`);
            if (header && grid) {
              header.addEventListener('click', () => {
                grid.classList.toggle('hidden');
              });
            }
          });

          // Hook Button Listeners
          document.querySelectorAll('.btn-confirm').forEach(btn => {
            btn.addEventListener('click', async (e) => {
              const id = e.target.dataset.id;
              e.target.disabled = true;
              e.target.textContent = 'Saving...';
              const success = await updateBookingAPI(id, { status: 'Confirmed' });
              if (success) fetchBookings();
            });
          });

          document.querySelectorAll('.btn-cancel').forEach(btn => {
            btn.addEventListener('click', async (e) => {
              if (confirm("Are you sure you want to cancel this appointment?")) {
                e.target.disabled = true;
                e.target.textContent = '...';
                const success = await updateBookingAPI(btn.dataset.id, { status: 'Cancelled' });
                if (success) fetchBookings();
              }
            });
          });

          document.querySelectorAll('.btn-reschedule').forEach(btn => {
            btn.addEventListener('click', (e) => {
              const dataset = e.currentTarget.dataset;
              rescheduleId.value = dataset.id;
              rescheduleDate.value = dataset.date;
              rescheduleTime.value = dataset.time;
              rescheduleModal.classList.remove('hidden');
            });
          });

          document.querySelectorAll('.btn-trigger-reminder').forEach(btn => {
            btn.addEventListener('click', (e) => {
              const dataset = e.currentTarget.dataset;
              const name = `${dataset.firstname} ${dataset.lastname}`;
              const phone = dataset.phone;
              const email = dataset.email;
              const date = dataset.date;
              const time = dataset.time;
              const service = dataset.service;

              // Populate modal fields
              reminderPatientName.textContent = name;
              reminderPatientPhone.textContent = `+91 ${phone.substring(0,5)} ${phone.substring(5)}`;
              
              if (email) {
                reminderPatientEmail.textContent = email;
                document.getElementById('reminder-patient-email-container').classList.remove('hidden');
              } else {
                reminderPatientEmail.textContent = '';
                document.getElementById('reminder-patient-email-container').classList.add('hidden');
              }

              // Prefill message template
              const message = `Hi ${dataset.firstname},\n\nThis is a friendly reminder for your upcoming appointment at AquaSmile Clinic.\n\n📅 Scheduled Slot: ${date} at ${time}\n🦷 Treatment: ${service}\n\nLooking forward to seeing you soon!`;
              reminderMessageText.value = message;
              
              // Store phone and email as data attributes on textarea
              reminderMessageText.dataset.phone = phone;
              reminderMessageText.dataset.email = email;

              // Update initial link href values
              updateReminderLinks();

              // Open Modal
              reminderModal.classList.remove('hidden');
            });
          });
        }
      };

      // Reschedule Modal Operations
      closeModalBtn.addEventListener('click', () => rescheduleModal.classList.add('hidden'));
      cancelRescheduleBtn.addEventListener('click', () => rescheduleModal.classList.add('hidden'));

      rescheduleForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = rescheduleId.value;
        const newDate = rescheduleDate.value;
        const newTime = rescheduleTime.value;

        rescheduleModal.classList.add('hidden');
        loadingState.classList.remove('hidden');
        bookingsSectionsContainer.classList.add('hidden');

        const success = await updateBookingAPI(id, {
          status: 'Rescheduled',
          date: newDate,
          time: newTime
        });

        if (success) {
          fetchBookings();
        } else {
          loadingState.classList.add('hidden');
          bookingsSectionsContainer.classList.remove('hidden');
        }
      });

      // Reminder Modal Operations
      const updateReminderLinks = () => {
        const text = encodeURIComponent(reminderMessageText.value);
        const phone = reminderMessageText.dataset.phone || '';
        const email = reminderMessageText.dataset.email || '';

        // SMS Link (support standard scheme, with separator fallback for iOS)
        const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
        const smsSeparator = isIOS ? '&' : '?';
        reminderSmsBtn.href = `sms:+91${phone}${smsSeparator}body=${text}`;

        // Email Link
        if (email) {
          reminderEmailBtn.href = `mailto:${email}?subject=Appointment%20Reminder%20-%20AquaSmile%20Clinic&body=${text}`;
          reminderEmailBtn.classList.remove('opacity-50', 'pointer-events-none', 'cursor-not-allowed');
        } else {
          reminderEmailBtn.removeAttribute('href');
          reminderEmailBtn.classList.add('opacity-50', 'pointer-events-none', 'cursor-not-allowed');
        }

        // WhatsApp Link
        reminderWaBtn.href = `https://wa.me/91${phone}?text=${text}`;
      };

      // Close handlers
      if (closeReminderModalBtn) {
        closeReminderModalBtn.addEventListener('click', () => reminderModal.classList.add('hidden'));
      }
      if (cancelReminderBtn) {
        cancelReminderBtn.addEventListener('click', () => reminderModal.classList.add('hidden'));
      }

      // Input listener on template textarea to update links in real time
      if (reminderMessageText) {
        reminderMessageText.addEventListener('input', updateReminderLinks);
      }

      // Copy text button click with visual state change animation
      if (reminderCopyBtn) {
        reminderCopyBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(reminderMessageText.value);
            const originalHtml = reminderCopyBtn.innerHTML;
            reminderCopyBtn.innerHTML = `
              <svg class="h-4 w-4 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>Copied!</span>
            `;
            reminderCopyBtn.classList.remove('hover:bg-slate-50');
            reminderCopyBtn.classList.add('border-emerald-200', 'bg-emerald-50', 'text-emerald-700');
            setTimeout(() => {
              reminderCopyBtn.innerHTML = originalHtml;
              reminderCopyBtn.classList.add('hover:bg-slate-50');
              reminderCopyBtn.classList.remove('border-emerald-200', 'bg-emerald-50', 'text-emerald-700');
            }, 2000);
          } catch (err) {
            console.error('Clipboard copy failed:', err);
            alert('Failed to copy message to clipboard.');
          }
        });
      }

      // Download CSV click handler
      if (downloadCsvBtn) {
        downloadCsvBtn.addEventListener('click', () => {
          if (filteredBookings.length === 0) {
            alert("No bookings to export.");
            return;
          }

          // CSV Headers
          const headers = ["Appointment ID", "First Name", "Last Name", "Phone", "Email", "Service", "Date", "Time", "Status", "Notes", "Created At"];
          
          // CSV Rows
          const escapeCsvVal = (val) => {
            if (val === null || val === undefined) return '';
            const str = String(val);
            if (str.includes(',') || str.includes('"') || str.includes('\n')) {
              return `"${str.replace(/"/g, '""')}"`;
            }
            return str;
          };

          const csvRows = [
            headers.join(','),
            ...filteredBookings.map(b => [
              escapeCsvVal(b.appointmentId),
              escapeCsvVal(b.firstName),
              escapeCsvVal(b.lastName),
              escapeCsvVal(b.phone),
              escapeCsvVal(b.email),
              escapeCsvVal(b.service),
              escapeCsvVal(b.date),
              escapeCsvVal(b.time),
              escapeCsvVal(b.status),
              escapeCsvVal(b.message),
              escapeCsvVal(b.timestamp)
            ].join(','))
          ];

          const csvContent = csvRows.join("\n");
          const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
          const url = URL.createObjectURL(blob);
          const link = document.createElement("a");
          link.setAttribute("href", url);
          const dateStr = new Date().toISOString().split('T')[0];
          link.setAttribute("download", `aquasmile_bookings_${dateStr}.csv`);
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
          URL.revokeObjectURL(url);
        });
      }

      // Filter change listeners
      searchInput.addEventListener('input', () => {
        if (searchInput.value.trim() !== '') {
          searchClearBtn.classList.remove('hidden');
        } else {
          searchClearBtn.classList.add('hidden');
        }
        applyFilters();
      });

      if (searchClearBtn) {
        searchClearBtn.addEventListener('click', () => {
          searchInput.value = '';
          searchClearBtn.classList.add('hidden');
          applyFilters();
        });
      }

      filterStatus.addEventListener('change', applyFilters);
      filterDate.addEventListener('change', () => {
        if (filterDate.value === 'CUSTOM') {
          customDateContainer.classList.remove('hidden');
          const todayStr = getIndianDateString();
          if (!customStartDate.value) customStartDate.value = todayStr;
          if (!customEndDate.value) customEndDate.value = todayStr;
        } else {
          customDateContainer.classList.add('hidden');
          customStartDate.value = '';
          customEndDate.value = '';
        }
        applyFilters();
      });

      customStartDate.addEventListener('change', applyFilters);
      customEndDate.addEventListener('change', applyFilters);

      // Check on startup
      checkAccess();
    </script>
  </body>
</html>
