<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  class={`block shrink-0 ${className}`}
  fill={isOutline ? 'none' : 'currentColor'}
  stroke={isOutline ? 'currentColor' : 'none'}
  stroke-width={isOutline ? '1.5' : undefined}
  aria-hidden="true"
  set:html={paths}
/>
