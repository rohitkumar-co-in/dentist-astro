---
import { buildWhatsAppLink, clinic } from '../lib/site';
import Icon from './Icon.astro';
---

<section id="services" class="services-section section-pad" data-reveal>
  <div class="page-shell">
    <!-- Header -->
    <div class="services-header">
      <div class="max-w-2xl">
        <span class="section-kicker">What we do</span>
        <h2 class="section-title mt-4">From cleanings to complex work</h2>
        <p class="section-copy">
          Whether you need a routine checkup or haven't seen a dentist in years — we've got you covered. No judgment, just real solutions.
        </p>
      </div>
      <a href="#appointment" class="action-btn-primary hidden lg:inline-flex">
        Book an Appointment →
      </a>
    </div>

    <!-- Services grid -->
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {clinic.services.map((service, i) => (
        <article class="service-card" style={`--delay:${i * 60}ms`}>
          <div class="service-icon-wrap">
            <Icon name={service.icon} class="h-8 w-8" size={30} />
          </div>
          <h3 class="service-name">{service.name}</h3>
          <p class="service-desc">{service.description}</p>
          <a
            href={buildWhatsAppLink(`Hi, I'd like to enquire about ${service.name}.`)}
            class="service-link"
          >
            Enquire on WhatsApp
            <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </article>
      ))}
    </div>

    <!-- Bottom CTA banner -->
    <div class="services-cta-banner mt-12">
      <div class="services-cta-left">
        <p class="text-lg font-semibold text-white">Not sure what you need?</p>
        <p class="mt-1 text-sm text-white/80">Message us — we'll help figure it out before your visit.</p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <a href={buildWhatsAppLink("Hi, I'm not sure what treatment I need. Can you help?")} class="services-cta-btn-wa" target="_blank" rel="noopener noreferrer">
          <Icon name="whatsapp" class="h-4 w-5" size={18} />
          Chat on WhatsApp
        </a>
        <a href="#appointment" class="services-cta-btn-book">
          Book a Checkup
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .services-section {
    background: white;
  }
  .services-header {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 24px;
  }

  .service-card {
    position: relative; display: flex; flex-direction: column;
    padding: 24px; border-radius: 18px;
    background: white;
    border: 1.5px solid rgba(0,119,182,0.1);
    box-shadow: 0 4px 20px rgba(43,45,66,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    animation: cardFadeUp 0.5s ease both;
    animation-delay: var(--delay, 0ms);
  }
  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,119,182,0.16);
    border-color: rgba(0,180,216,0.4);
  }
  .service-card::before {
    content: '';
    position: absolute; inset: 0; border-radius: 18px;
    background: linear-gradient(135deg, rgba(202,240,248,0.4) 0%, transparent 60%);
    opacity: 0; transition: opacity 0.3s;
  }
  .service-card:hover::before { opacity: 1; }

  @keyframes cardFadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .service-icon-wrap {
    display: flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: 16px;
    background: linear-gradient(135deg, #CAF0F8, #90E0EF);
    margin-bottom: 16px; flex-shrink: 0;
    transition: transform 0.3s ease;
  }
  .service-card:hover .service-icon-wrap { transform: scale(1.08) rotate(-3deg); }

  .service-name {
    font-size: 1.0625rem; font-weight: 700; color: #2B2D42; margin-bottom: 8px;
  }
  .service-desc {
    flex: 1; font-size: 0.875rem; line-height: 1.65; color: rgba(43,45,66,0.65);
    margin-bottom: 18px;
  }
  .service-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.8125rem; font-weight: 600; color: #0077B6;
    transition: color 0.2s, gap 0.2s;
    margin-top: auto;
  }
  .service-link:hover { color: #00B4D8; gap: 10px; }

  .services-cta-banner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 20px; flex-wrap: wrap;
    padding: 28px 32px; border-radius: 20px;
    background: linear-gradient(135deg, #0077B6 0%, #00B4D8 100%);
    box-shadow: 0 16px 48px rgba(0,119,182,0.3);
  }
  .services-cta-left { flex: 1; }
  .services-cta-btn-wa {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 12px;
    background: #25D366; color: white;
    font-size: 0.875rem; font-weight: 600;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .services-cta-btn-wa:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(37,211,102,0.4); }
  .services-cta-btn-book {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 12px;
    background: white; color: #0077B6;
    font-size: 0.875rem; font-weight: 700;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .services-cta-btn-book:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,255,255,0.3); }
</style>
